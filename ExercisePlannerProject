import random

# Project Summary: My Exercise Routine Planner is a Python program that helps users create a customized workout plan based on their fitness goals. The program asks questions like the user’s name, height, workout goal, preferred muscle group, and how many days they want to work out. Using these answers, it builds either a strength‑training or cardio routine that matches the user’s choices. The program now creates a simple multi‑day workout schedule with multiple exercises per day, each including sets and reps so the routine feels more like a real workout plan. The exercises rotate across the days to keep the schedule balanced and beginner‑friendly. At the end, the program displays the full plan in a clean, easy‑to‑read format that shows each day and the exercises assigned to it.

# Flow of Program: I want my code to: collect user info, identify goal type, select exercises, generate the routine, and display the final plan.

# //////////////////////////////////////////////////////////////////////////////
# Code to collect user info:
# //////////////////////////////////////////////////////////////////////////////

def get_user_info():
    # This function asks the user questions.
    # We save the answers so we can build the workout plan later.

    print("Welcome to the Exercise Routine Planner!")
    print("Please answer the questions below.\n")

    name = input("What is your name? ")
    height_cm = input("What is your height in centimeters? ")

    print("\nWhat is your main workout goal?")
    print("1 - Strength training")
    print("2 - Cardio")
    goal_choice = input("Enter 1 for Strength or 2 for Cardio: ")

    if goal_choice == "1":
        goal_type = "strength"
    elif goal_choice == "2":
        goal_type = "cardio"
    else:
        print("Invalid choice. Setting goal to strength.")
        goal_type = "strength"

    if goal_type == "strength":
        print("\nWhich muscle group do you want to focus on?")
        print("Options: upper, lower, full")
        muscle_group = input("Type your choice: ").strip().lower()
    else:
        muscle_group = None

    days = input("\nHow many days per week do you want to work out? ")

    user_info = {
        "name": name,
        "height_cm": height_cm,
        "goal_type": goal_type,
        "muscle_group": muscle_group,
        "days": days
    }

    return user_info

# //////////////////////////////////////////////////////////////////////////////
# Code to identify goal type:
# //////////////////////////////////////////////////////////////////////////////

def identify_goal_type(user_info):
    # This function looks at the user's goal.
    # The goal is already saved inside the user_info dictionary.

    goal = user_info["goal_type"]  # this will be "strength" or "cardio"

    # We check the goal and return it.
    # This helps the next part of the program know which path to follow.
    if goal == "strength":
        return "strength"
    else:
        return "cardio"

