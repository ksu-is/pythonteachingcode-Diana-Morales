# UPDATED VERSION — prevents back‑to‑back repeats
def generate_routine(exercises, user_info):
    # This version gives 3 exercises per day.

    days = int(user_info["days"])
    routine = []

    # Shuffle exercises so the order changes each run
    random.shuffle(exercises)

    # Track last day's exercises to avoid repeats
    previous_day = set()

    for day in range(days):
        day_plan = []
        used_today = set()

        # Pick 3 exercises for the day
        for exercise in exercises:
            if exercise not in previous_day and exercise not in used_today:
                day_plan.append(exercise)
                used_today.add(exercise)

            if len(day_plan) == 3:
                break

        # If we somehow run out (rare), fill remaining slots
        while len(day_plan) < 3:
            choice = random.choice(exercises)
            if choice not in previous_day and choice not in day_plan:
                day_plan.append(choice)

        routine.append(day_plan)
        previous_day = set(day_plan)

    return routine

